[Desktop Entry]
Type=Application
Name=Web Viewer (Chromium)
Comment=Views images, PDFs, and web pages inside the workbench
Exec=/usr/local/bin/pairputer-chromium %U
Terminal=false
Categories=Network;WebBrowser;Graphics;Viewer;
MimeType=text/html;application/xhtml+xml;application/pdf;image/png;image/jpeg;image/gif;image/webp;image/bmp;image/svg+xml;image/avif;image/apng;image/x-icon;image/tiff;
NoDisplay=false
